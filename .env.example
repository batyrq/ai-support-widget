# ====================================================================
# ai-support-widget — пример конфигурации. Скопируй в .env.
# ====================================================================

# --- PostgreSQL (через docker-compose) ---
POSTGRES_USER=asw
POSTGRES_PASSWORD=asw_password
POSTGRES_DB=asw
# Хостовый порт. Если 5434 занят — поменяй.
POSTGRES_PORT=5434

# Строка подключения для Prisma / Next.js (порт = POSTGRES_PORT выше).
DATABASE_URL=postgresql://asw:asw_password@localhost:5434/asw?schema=public

# --- Groq (LLM, BYOK) ---
# Серверный ключ — ОПЦИОНАЛЬНЫЙ фоллбэк (для встроенного на свой сайт виджета).
# В дашборде каждый вводит свой ключ сам (он шлётся в заголовке x-groq-key и
# не сохраняется на сервере). Бесплатный ключ: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Эмбеддинги (локально, без ключа) ---
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# Базовый публичный URL приложения (для сниппета встраивания виджета).
NEXT_PUBLIC_APP_URL=http://localhost:3000
