// Prisma schema для ai-support-widget.
// Векторная колонка Chunk.embedding объявлена как Unsupported("vector(384)") —
// Prisma создаёт колонку нужного типа, а читаем/пишем мы её через raw SQL.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Bot {
  id             String   @id @default(uuid())
  name           String
  // Системный промпт — характер и правила бота.
  systemPrompt   String   @default("Ты — дружелюбный ассистент поддержки. Отвечай кратко и по делу, опираясь на базу знаний и приводя ссылки на источники [1], [2].")
  // Настройки внешнего вида виджета.
  accentColor    String   @default("#4f46e5")
  welcomeMessage String   @default("Здравствуйте! Я бот поддержки. Чем могу помочь?")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  documents     Document[]
  chunks        Chunk[]
  conversations Conversation[]
}

model Document {
  id         String   @id @default(uuid())
  filename   String
  mimeType   String
  chunkCount Int      @default(0)
  createdAt  DateTime @default(now())

  botId  String
  bot    Bot     @relation(fields: [botId], references: [id], onDelete: Cascade)
  chunks Chunk[]

  @@index([botId])
}

model Chunk {
  id         String   @id @default(uuid())
  content    String
  chunkIndex Int      @default(0)
  // vector(384) из pgvector. Только raw SQL.
  embedding  Unsupported("vector(384)")?
  createdAt  DateTime @default(now())

  botId      String
  bot        Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([botId])
  @@index([documentId])
}

model Conversation {
  id        String   @id @default(uuid())
  // Анонимный идентификатор посетителя (из localStorage виджета).
  visitorId String?
  createdAt DateTime @default(now())

  botId    String
  bot      Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([botId])
}

model Message {
  id        String   @id @default(uuid())
  role      String // "user" | "assistant"
  content   String
  // JSON с цитатами (источники ответа) для логов.
  meta      Json?
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}
